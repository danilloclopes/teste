# Banco de dados
MYSQL_ROOT_PASSWORD=rootpass
DB_USER=aux-user
DB_PASSWORD=123

# Back-end: origem do front-end permitida para CORS
# Em produção, coloque a URL exata do seu front-end hospedado
FRONTEND_ORIGIN=http://localhost:3000

# Front-end: URL da API back-end
# Em produção, coloque a URL pública do back-end (ex: https://api.seusite.com/api)
VITE_API_URL=http://localhost:8080/api
